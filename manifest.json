{
  "display_information": {
    "name": "Claude Code Bridge",
    "description": "SlackからClaude Code CLIをリモート操作するブリッジ",
    "background_color": "#4a154b"
  },
  "features": {
    "bot_user": {
      "display_name": "Claude Code",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/status-cc",
        "description": "Show running task status",
        "should_escape": false
      },
      {
        "command": "/cancel-cc",
        "description": "Cancel a running task",
        "usage_hint": "[task ID]",
        "should_escape": false
      },
      {
        "command": "/sessions-cc",
        "description": "List sessions in this channel",
        "should_escape": false
      },
      {
        "command": "/root-cc",
        "description": "Set/show channel root directory",
        "usage_hint": "[path|clear]",
        "should_escape": false
      },
      {
        "command": "/resume-cc",
        "description": "Resume a running Claude CLI session",
        "usage_hint": "[PID] [task]",
        "should_escape": false
      },
      {
        "command": "/bind-cc",
        "description": "Live-connect to a running Claude CLI process",
        "usage_hint": "[PID]",
        "should_escape": false
      },
      {
        "command": "/cc",
        "description": "Run a Claude Code task",
        "usage_hint": "task description",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "groups:history",
        "files:read",
        "files:write",
        "commands"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups"
      ]
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
